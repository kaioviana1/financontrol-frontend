# ============================================================
# FinanControl — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA comite o arquivo .env no controle de versão
# ============================================================

# URL base da API (sem barra no final, incluindo /api)
# Desenvolvimento: http://localhost:3000/api
# Produção:        https://api.seudominio.com/api
VITE_API_URL=http://localhost:3000/api

# Nome da aplicação (usado em meta tags e titles)
VITE_APP_NAME=FinanControl

# Versão da aplicação
VITE_APP_VERSION=1.0.0

# Timeout das requisições HTTP em milissegundos
VITE_API_TIMEOUT=15000
